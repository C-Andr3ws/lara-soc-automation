# LARA — API Keys Template
# Copy this file to .env and fill in your actual values
# Never commit your real .env file to GitHub

# OpenAI API (GPT-4.1 Mini)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# AbuseIPDB (IP Reputation)
# Get from: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# VirusTotal (File Hash + IP Analysis)
# Get from: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# DFIR-IRIS (Case Management)
# Generated in DFIR-IRIS admin panel after deployment
# Profile > My Settings > API Keys
DFIR_IRIS_API_KEY=your_dfir_iris_api_key_here
DFIR_IRIS_URL=https://192.168.106.131  # Replace with your IRIS server IP

# Slack (Analyst Notifications)
# Create an Incoming Webhook at: https://api.slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# n8n instance URL (used internally)
N8N_URL=http://192.168.106.130:5678  # Replace with your n8n server IP

# NOTE: If you want a fully free, local setup — replace OpenAI with Ollama.
# Run Ollama locally and point the n8n HTTP Request node to:
# http://localhost:11434/api/generate
# No API key needed. Recommended models: mistral, llama3
